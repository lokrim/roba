# ── Vertex AI ────────────────────────────────────────────────────────────────
# GCP project that hosts your Vertex AI API.  Required for LLM + Live voice.
GOOGLE_CLOUD_PROJECT=
# Region where the models are served (must match models enabled in your project).
GOOGLE_CLOUD_LOCATION=us-central1
# Path to a service-account JSON with the "Vertex AI User" role.
# Defaults to roba.json in the repo root; omit to use Application Default Credentials.
GOOGLE_APPLICATION_CREDENTIALS=roba.json

# ── Model IDs ─────────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio

# ── Optional weather API ──────────────────────────────────────────────────────
WEATHER_API_BASE=

# ── App config ────────────────────────────────────────────────────────────────
DEMO_MODE=combined
DB_PATH=
INVENTORY_SHORTAGE_SIGNALS_ENABLED=true
VOICE_EMIT_LEGACY_USER_FACT=true
